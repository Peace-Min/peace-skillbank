# =============================================================================
# Sparrow Track-A auto-fix config  (버킷1: LLM 없이 결정론적으로 정리 가능한 스타일)
#
# 사용법: 이 파일을 정리할 프로젝트/솔루션 루트에  ".editorconfig"  로 *복사*한 뒤
#         VS "코드 정리 / Fix All in Solution"  또는  dotnet format style  실행.
#         (여기서는 일부러 .editorconfig 가 아닌 이름으로 둠 = 리포 오염 방지)
#         자세한 절차·검증·커밋 규칙은  track-a-autofix.md
#
# 검증됨(2026-07): net472 *레거시(non-SDK)* 프로젝트에서 아래 5종 자동수정 확인.
# 주의:   Roslyn 규칙 경계 != Sparrow 경계일 수 있음 -> 적용 후 Sparrow 재분석으로
#         실제 검출 건수 감소를 반드시 확인. 과도한 churn이면 var_elsewhere = false 로 좁힐 것.
# =============================================================================
root = true

[*.cs]
# --- var / 암시적 타이핑 -----------------------------------------------------
#   Sparrow: OBVIOUS_VARIABLE_TYPE / OBJECT_INSTANTIATION / LOOP_VARIABLE
csharp_style_var_for_built_in_types = true:suggestion
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere = true:suggestion        # broad. 보수적으로 하려면 false (명백한 타입만 var화)
dotnet_diagnostic.IDE0007.severity = suggestion     # use var
dotnet_diagnostic.IDE0008.severity = suggestion     # use explicit type (역방향; var 선호라 미발동)

# --- 명확화 괄호 -------------------------------------------------------------
#   Sparrow: MISSING_PARENTHESIS_IN_EXPRESSION
dotnet_style_parentheses_in_arithmetic_binary_operators = always_for_clarity:suggestion
dotnet_style_parentheses_in_relational_binary_operators = always_for_clarity:suggestion
dotnet_style_parentheses_in_other_binary_operators = always_for_clarity:suggestion
dotnet_diagnostic.IDE0048.severity = suggestion

# --- 객체 이니셜라이저 -------------------------------------------------------
#   Sparrow: OBJECT_INITIALIZATION.NOT_USED_INITIALIZER
dotnet_style_object_initializer = true:suggestion
dotnet_diagnostic.IDE0017.severity = suggestion
