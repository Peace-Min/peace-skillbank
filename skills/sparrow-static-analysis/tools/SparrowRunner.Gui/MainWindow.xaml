<Window x:Class="SparrowRunner.Gui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sparrow Track A/B Runner"
        Width="1180" Height="820"
        MinWidth="980" MinHeight="700"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI, Malgun Gothic" FontSize="13">

    <Window.Resources>
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <Style x:Key="HintText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#666666"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="MinWidth" Value="88"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="0,0,18,7"/>
        </Style>
        <Style x:Key="RuleGroup" TargetType="GroupBox">
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Padding" Value="10"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="170"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="Sparrow Track A/B Runner" FontSize="19" FontWeight="Bold"/>
            <TextBlock Text="Track A/B PowerShell CLI를 호출하는 WPF 래퍼입니다. 체크박스를 선택하면 아래에서 대응 스패로우 체커와 변경 전/후 예시를 확인할 수 있습니다."
                       Style="{StaticResource HintText}"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,0,0,14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Text="대상 솔루션/프로젝트/소스 폴더" Style="{StaticResource SectionLabel}"/>
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TargetPathBox" Height="28" VerticalContentAlignment="Center"/>
                <Button x:Name="BrowseFileButton" Grid.Column="1" Content="파일 선택" Margin="8,0,0,0"
                        Click="BrowseFileButton_Click"/>
                <Button x:Name="BrowseFolderButton" Grid.Column="2" Content="폴더 선택" Margin="8,0,0,0"
                        Click="BrowseFolderButton_Click"/>
            </Grid>
        </Grid>

        <TabControl Grid.Row="2" x:Name="RulesTabs">
            <TabItem Header="Track A - 코딩규칙">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12">
                        <CheckBox x:Name="RunTrackASyntaxCheck" Content="Track A 2차 Roslyn 자동수정 실행 (권장)"
                                  IsChecked="True" FontWeight="SemiBold"/>
                        <GroupBox Header="기본 자동수정 규칙" Style="{StaticResource RuleGroup}">
                            <WrapPanel>
                                <CheckBox x:Name="ASObjectVarSafe" Content="객체 생성 명시 타입을 var로 변경" IsChecked="True"/>
                                <CheckBox x:Name="ASObviousVar" Content="명확한 지역변수 타입을 var로 변경" IsChecked="True"/>
                                <CheckBox x:Name="ASArrayVarSafe" Content="배열 초기화 문법 간소화" IsChecked="True"/>
                                <CheckBox x:Name="ASParens" Content="논리식 괄호 명확화" IsChecked="True"/>
                            </WrapPanel>
                        </GroupBox>
                        <GroupBox Header="선택 자동수정 규칙" Style="{StaticResource RuleGroup}">
                            <WrapPanel>
                                <CheckBox x:Name="ASForeachCast" Content="[검토필요] foreach 명시 타입을 Cast&lt;T&gt; + var로 변경"/>
                                <CheckBox x:Name="ASObjectInitializer" Content="객체 생성 후 연속 대입을 object initializer로 통합"/>
                                <CheckBox x:Name="ASNullVar" Content="[검토필요] 명시 지역변수를 typed null var로 초기화"/>
                                <CheckBox x:Name="ASObjectVarNarrowing" Content="[검토필요] 인터페이스/상위 타입 선언을 var로 축소"/>
                                <CheckBox x:Name="ASLocalConst" Content="[검토필요] 지역 const를 var 지역변수로 변경"/>
                                <CheckBox x:Name="ASArrayVarNarrowing" Content="[검토필요] 배열 선언을 var + new[]로 축소"/>
                                <CheckBox x:Name="ASForVar" Content="for 루프 초기화 변수를 var로 변경"/>
                                <CheckBox x:Name="ASFieldSplit" Content="한 줄 다중 필드 선언 분리"/>
                                <CheckBox x:Name="ASEmptyStmt" Content="불필요한 빈 문장 세미콜론 제거"/>
                                <CheckBox x:Name="ASForHoist" Content="[검토필요] for 다중 선언자를 루프 밖으로 분리"/>
                            </WrapPanel>
                        </GroupBox>

                        <Expander Header="Track A 1차 dotnet format 보조 실행 (기본 비활성)" IsExpanded="False" Margin="0,0,0,12">
                            <StackPanel Margin="0,8,0,0">
                                <CheckBox x:Name="RunTrackAFormatCheck" Content="Run-TrackA.ps1 실행"
                                          IsChecked="False" FontWeight="SemiBold"/>
                                <GroupBox Header="1차 dotnet format 규칙" Style="{StaticResource RuleGroup}">
                                    <WrapPanel>
                                        <CheckBox x:Name="A1Var" Content="명시 타입을 var로 변경" IsChecked="True"/>
                                        <CheckBox x:Name="A1Parens" Content="논리식 괄호 명확화" IsChecked="True"/>
                                        <CheckBox x:Name="A1Initializer" Content="object initializer 적용" IsChecked="True"/>
                                    </WrapPanel>
                                </GroupBox>
                            </StackPanel>
                        </Expander>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Track B - 주석/레이아웃">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12">
                        <CheckBox x:Name="RunTrackBCheck" Content="Track B 주석/레이아웃 자동수정 실행"
                                  IsChecked="True" FontWeight="SemiBold"/>
                        <GroupBox Header="기본 주석 규칙" Style="{StaticResource RuleGroup}">
                            <WrapPanel>
                                <CheckBox x:Name="BTrailing" Content="코드 뒤 주석을 위 줄로 이동" IsChecked="True"/>
                                <CheckBox x:Name="BSpace" Content="주석 기호 뒤 공백 추가" IsChecked="True"/>
                                <CheckBox x:Name="BPeriod" Content="주석 끝 마침표 추가" IsChecked="True"/>
                                <CheckBox x:Name="BCapitalize" Content="주석 첫 영문 대문자화" IsChecked="True"/>
                            </WrapPanel>
                        </GroupBox>
                        <GroupBox Header="선택 레이아웃/주석 규칙" Style="{StaticResource RuleGroup}">
                            <WrapPanel>
                                <CheckBox x:Name="BFlatten" Content="별표/Doxygen 블록 주석을 한 줄 주석으로 평탄화"/>
                                <CheckBox x:Name="BMemberBlank" Content="멤버 선언 사이 빈 줄 추가"/>
                                <CheckBox x:Name="BOneDeclaration" Content="한 줄 다중 선언 분리"/>
                                <CheckBox x:Name="BOneStatement" Content="한 줄 다중 구문 분리"/>
                                <CheckBox x:Name="BContinuation" Content="여러 줄 문장 들여쓰기 보정"/>
                                <CheckBox x:Name="BLinqAlign" Content="LINQ 쿼리 절 정렬"/>
                                <CheckBox x:Name="BBlockPromote" Content="[검토필요] inline block 주석을 위 줄로 이동"/>
                            </WrapPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="옵션">
                <StackPanel Margin="12">
                    <TextBlock Text="실행 옵션" Style="{StaticResource SectionLabel}"/>
                    <WrapPanel Margin="0,0,0,12">
                        <CheckBox x:Name="CommitCheck" Content="규칙별 커밋" IsChecked="True"/>
                        <CheckBox x:Name="DryRunCheck" Content="DryRun (파일 변경 없음)" Checked="DryRunCheck_Changed" Unchecked="DryRunCheck_Changed"/>
                        <CheckBox x:Name="IncludeGeneratedCheck" Content="Track B 생성 파일 포함"/>
                    </WrapPanel>
                    <TextBlock Text="DryRun을 켜면 커밋은 자동으로 비활성화됩니다. 실제 수정 전 변경 후보를 확인할 때 사용하세요."
                               Style="{StaticResource HintText}"/>
                </StackPanel>
            </TabItem>
        </TabControl>

        <GroupBox Grid.Row="3" Header="선택한 규칙의 변경 전/후 예시" Margin="0,12,0,0" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock x:Name="RuleInfoTitle" FontWeight="SemiBold" FontSize="14"/>
                <TextBlock x:Name="RuleInfoBody" Grid.Row="1" Margin="0,5,0,6"
                           TextWrapping="Wrap" Foreground="#333333"/>
                <TextBox x:Name="RuleInfoExample" Grid.Row="2"
                         IsReadOnly="True" IsUndoEnabled="False"
                         FontFamily="Consolas" FontSize="12"
                         MinHeight="62" MaxHeight="96"
                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                         TextWrapping="NoWrap" Background="#F7F7F7" BorderBrush="#D0D0D0"
                         Padding="6"/>
            </Grid>
        </GroupBox>

        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,12,0,10">
            <Button x:Name="RunButton" Content="실행" Click="RunButton_Click"
                    MinWidth="110" FontWeight="SemiBold" Background="#0067C0" Foreground="White"/>
            <Button x:Name="StopButton" Content="중지" Click="StopButton_Click"
                    Margin="10,0,0,0" IsEnabled="False"/>
            <Button x:Name="OpenTargetButton" Content="대상 폴더 열기" Click="OpenTargetButton_Click"
                    Margin="10,0,0,0"/>
            <Button x:Name="ClearLogButton" Content="로그 지우기" Click="ClearLogButton_Click"
                    Margin="10,0,0,0"/>
        </StackPanel>

        <TextBox x:Name="LogBox" Grid.Row="5"
                 IsReadOnly="True" IsUndoEnabled="False"
                 FontFamily="Consolas" FontSize="12"
                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                 TextWrapping="NoWrap" Background="#1E1E1E" Foreground="#DCDCDC"
                 Padding="6"/>

        <TextBlock x:Name="StatusText" Grid.Row="6" Text="대기 중" Margin="0,8,0,0"
                   Foreground="#666666"/>
    </Grid>
</Window>
