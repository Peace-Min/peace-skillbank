<Window x:Class="SparrowRunner.Gui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sparrow Track A/B Runner"
        Width="1120" Height="780"
        MinWidth="960" MinHeight="680"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI, Malgun Gothic" FontSize="13">

    <Window.Resources>
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <Style x:Key="HintText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#666666"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="MinWidth" Value="88"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="0,0,18,7"/>
        </Style>
        <Style x:Key="RuleGroup" TargetType="GroupBox">
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Padding" Value="10"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="190"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="Sparrow Track A/B Runner" FontSize="19" FontWeight="Bold"/>
            <TextBlock Text="Track A/B PowerShell CLI를 호출하는 WPF 래퍼입니다. 체크박스를 선택하면 아래 설명 패널에서 대응 체커와 변경 예시를 확인할 수 있습니다."
                       Style="{StaticResource HintText}"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,0,0,14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Text="대상 솔루션/프로젝트/소스 폴더" Style="{StaticResource SectionLabel}"/>
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TargetPathBox" Height="28" VerticalContentAlignment="Center"/>
                <Button x:Name="BrowseFileButton" Grid.Column="1" Content="파일 선택" Margin="8,0,0,0"
                        Click="BrowseFileButton_Click"/>
                <Button x:Name="BrowseFolderButton" Grid.Column="2" Content="폴더 선택" Margin="8,0,0,0"
                        Click="BrowseFolderButton_Click"/>
            </Grid>
        </Grid>

        <TabControl Grid.Row="2" x:Name="RulesTabs">
            <TabItem Header="Track A - 코딩규칙">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12">
                        <CheckBox x:Name="RunTrackAFormatCheck" Content="Track A 1차 dotnet format 실행 (Run-TrackA.ps1)"
                                  IsChecked="False" FontWeight="SemiBold"/>
                        <GroupBox Header="1차 dotnet format 규칙" Style="{StaticResource RuleGroup}">
                            <WrapPanel>
                                <CheckBox x:Name="A1Var" Content="var" IsChecked="True"/>
                                <CheckBox x:Name="A1Parens" Content="parens" IsChecked="True"/>
                                <CheckBox x:Name="A1Initializer" Content="initializer" IsChecked="True"/>
                            </WrapPanel>
                        </GroupBox>

                        <CheckBox x:Name="RunTrackASyntaxCheck" Content="Track A 2차 Roslyn 실행 (Run-SparrowSyntaxFix.ps1)"
                                  IsChecked="True" FontWeight="SemiBold"/>
                        <GroupBox Header="기본 규칙" Style="{StaticResource RuleGroup}">
                            <WrapPanel>
                                <CheckBox x:Name="ASObjectVarSafe" Content="objectvar-safe" IsChecked="True"/>
                                <CheckBox x:Name="ASObviousVar" Content="obviousvar" IsChecked="True"/>
                                <CheckBox x:Name="ASArrayVarSafe" Content="arrayvar-safe" IsChecked="True"/>
                                <CheckBox x:Name="ASParens" Content="parens" IsChecked="True"/>
                            </WrapPanel>
                        </GroupBox>
                        <GroupBox Header="검토필요/선택 규칙" Style="{StaticResource RuleGroup}">
                            <WrapPanel>
                                <CheckBox x:Name="ASForeachCast" Content="foreachcast"/>
                                <CheckBox x:Name="ASObjectInitializer" Content="objectinitializer"/>
                                <CheckBox x:Name="ASNullVar" Content="nullvar"/>
                                <CheckBox x:Name="ASObjectVarNarrowing" Content="objectvar-narrowing"/>
                                <CheckBox x:Name="ASLocalConst" Content="localconst"/>
                                <CheckBox x:Name="ASArrayVarNarrowing" Content="arrayvar-narrowing"/>
                                <CheckBox x:Name="ASForVar" Content="forvar"/>
                                <CheckBox x:Name="ASFieldSplit" Content="fieldsplit"/>
                                <CheckBox x:Name="ASEmptyStmt" Content="emptystmt"/>
                                <CheckBox x:Name="ASForHoist" Content="forhoist"/>
                            </WrapPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Track B - 주석/레이아웃">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12">
                        <CheckBox x:Name="RunTrackBCheck" Content="Track B 실행 (Run-SparrowCommentFix.ps1)"
                                  IsChecked="True" FontWeight="SemiBold"/>
                        <GroupBox Header="기본 주석 규칙" Style="{StaticResource RuleGroup}">
                            <WrapPanel>
                                <CheckBox x:Name="BTrailing" Content="trailing" IsChecked="True"/>
                                <CheckBox x:Name="BSpace" Content="space" IsChecked="True"/>
                                <CheckBox x:Name="BPeriod" Content="period" IsChecked="True"/>
                                <CheckBox x:Name="BCapitalize" Content="capitalize" IsChecked="True"/>
                            </WrapPanel>
                        </GroupBox>
                        <GroupBox Header="선택 규칙" Style="{StaticResource RuleGroup}">
                            <WrapPanel>
                                <CheckBox x:Name="BFlatten" Content="flatten"/>
                                <CheckBox x:Name="BMemberBlank" Content="memberblank"/>
                                <CheckBox x:Name="BOneDeclaration" Content="onedeclaration"/>
                                <CheckBox x:Name="BOneStatement" Content="onestatement"/>
                                <CheckBox x:Name="BContinuation" Content="continuation"/>
                                <CheckBox x:Name="BLinqAlign" Content="linqalign"/>
                                <CheckBox x:Name="BBlockPromote" Content="blockpromote"/>
                            </WrapPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="옵션">
                <StackPanel Margin="12">
                    <TextBlock Text="실행 옵션" Style="{StaticResource SectionLabel}"/>
                    <WrapPanel Margin="0,0,0,12">
                        <CheckBox x:Name="CommitCheck" Content="규칙별 커밋" IsChecked="True"/>
                        <CheckBox x:Name="DryRunCheck" Content="DryRun (파일 변경 없음)" Checked="DryRunCheck_Changed" Unchecked="DryRunCheck_Changed"/>
                        <CheckBox x:Name="IncludeGeneratedCheck" Content="Track B 생성 파일 포함"/>
                    </WrapPanel>
                    <TextBlock Text="DryRun을 켜면 커밋은 자동으로 비활성화됩니다. 실제 수정 전 변경 후보를 확인할 때 사용하세요."
                               Style="{StaticResource HintText}"/>
                </StackPanel>
            </TabItem>
        </TabControl>

        <GroupBox Grid.Row="3" Header="선택 규칙 설명" Margin="0,12,0,0" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock x:Name="RuleInfoTitle" FontWeight="SemiBold" FontSize="14"/>
                <TextBlock x:Name="RuleInfoBody" Grid.Row="1" Margin="0,5,0,6"
                           TextWrapping="Wrap" Foreground="#333333"/>
                <TextBox x:Name="RuleInfoExample" Grid.Row="2"
                         IsReadOnly="True" IsUndoEnabled="False"
                         FontFamily="Consolas" FontSize="12"
                         MinHeight="54" MaxHeight="84"
                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                         TextWrapping="NoWrap" Background="#F7F7F7" BorderBrush="#D0D0D0"
                         Padding="6"/>
            </Grid>
        </GroupBox>

        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,12,0,10">
            <Button x:Name="RunButton" Content="실행" Click="RunButton_Click"
                    MinWidth="110" FontWeight="SemiBold" Background="#0067C0" Foreground="White"/>
            <Button x:Name="StopButton" Content="중지" Click="StopButton_Click"
                    Margin="10,0,0,0" IsEnabled="False"/>
            <Button x:Name="OpenTargetButton" Content="대상 폴더 열기" Click="OpenTargetButton_Click"
                    Margin="10,0,0,0"/>
            <Button x:Name="ClearLogButton" Content="로그 지우기" Click="ClearLogButton_Click"
                    Margin="10,0,0,0"/>
        </StackPanel>

        <TextBox x:Name="LogBox" Grid.Row="5"
                 IsReadOnly="True" IsUndoEnabled="False"
                 FontFamily="Consolas" FontSize="12"
                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                 TextWrapping="NoWrap" Background="#1E1E1E" Foreground="#DCDCDC"
                 Padding="6"/>

        <TextBlock x:Name="StatusText" Grid.Row="6" Text="대기 중" Margin="0,8,0,0"
                   Foreground="#666666"/>
    </Grid>
</Window>
