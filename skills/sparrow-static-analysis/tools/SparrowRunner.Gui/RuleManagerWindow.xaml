<Window x:Class="SparrowRunner.Gui.RuleManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="체커 룰 관리"
        Width="960" Height="700"
        MinWidth="820" MinHeight="560"
        WindowStartupLocation="CenterOwner"
        Background="#F4F6F8"
        FontFamily="Segoe UI, Malgun Gothic" FontSize="13">

    <Window.Resources>
        <SolidColorBrush x:Key="AccentBrush" Color="#0064FF"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#191F28"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#4E5968"/>
        <SolidColorBrush x:Key="TextTertiaryBrush" Color="#8B95A1"/>
        <SolidColorBrush x:Key="LineBrush" Color="#E5E8EB"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF"/>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="MutedText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="MinWidth" Value="72"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#D1D6DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Foreground" Value="#D64550"/>
            <Setter Property="BorderBrush" Value="#F0C7CA"/>
        </Style>

        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="#F8FAFB"/>
            <Setter Property="BorderBrush" Value="#D1D6DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="체커 룰(가이드) 관리" FontSize="20" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}"/>
            <TextBlock Text="references/checkers 폴더의 체커별 가이드(.md)를 추가·삭제·편집합니다. 여기서 추가한 룰은 다음 Track C 실행부터 자동 반영됩니다."
                       Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- TOP: XLS checker discovery -->
        <Border Grid.Row="1" Background="{StaticResource PanelBrush}" CornerRadius="14"
                BorderBrush="{StaticResource LineBrush}" BorderThickness="1"
                Padding="14" Margin="0,0,0,12">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="이 XLS의 체커" Style="{StaticResource SectionTitle}" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" x:Name="AddFromXlsButton" Content="이 체커 룰 추가"
                            Click="AddFromXlsButton_Click"/>
                </Grid>
                <TextBlock x:Name="XlsHintText" Style="{StaticResource MutedText}" TextWrapping="Wrap"
                           Margin="0,0,0,8"
                           Text="Sparrow 결과 XLS의 체커 키를 나열합니다. 미등록 항목을 더블클릭하면 그 키로 새 룰 추가가 채워집니다."/>
                <ListBox x:Name="XlsCheckerList" Height="128"
                         BorderBrush="#E5E8EB" BorderThickness="1" Background="#F8FAFB"
                         MouseDoubleClick="XlsCheckerList_MouseDoubleClick"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="2,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Key}" Foreground="#191F28" VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>
                                <Border Grid.Column="1" CornerRadius="7" Padding="8,2"
                                        Background="{Binding BadgeBackground}">
                                    <TextBlock Text="{Binding StatusLabel}" Foreground="{Binding BadgeForeground}"
                                               FontSize="11" FontWeight="SemiBold"/>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
        </Border>

        <!-- MAIN: registered list (left) + editor (right) -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="330"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: registered rules -->
            <Border Background="{StaticResource PanelBrush}" CornerRadius="14"
                    BorderBrush="{StaticResource LineBrush}" BorderThickness="1" Padding="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" x:Name="RegisteredTitle" Text="등록된 체커 룰"
                               Style="{StaticResource SectionTitle}"/>

                    <ListBox Grid.Row="1" x:Name="RegisteredList"
                             BorderBrush="#E5E8EB" BorderThickness="1" Background="#F8FAFB"
                             SelectionChanged="RegisteredList_SelectionChanged"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="2,4">
                                    <TextBlock Text="{Binding Key}" Foreground="#191F28" FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding Title}" Foreground="#8B95A1" FontSize="11"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Grid Grid.Row="2" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" x:Name="NewRuleButton" Content="새 룰" Click="NewRuleButton_Click"/>
                        <Button Grid.Column="2" x:Name="SaveRuleButton" Content="저장" Style="{StaticResource PrimaryButton}"
                                Click="SaveRuleButton_Click"/>
                        <Button Grid.Column="4" x:Name="RemoveRuleButton" Content="제거" Style="{StaticResource DangerButton}"
                                Click="RemoveRuleButton_Click"/>
                    </Grid>

                    <Border Grid.Row="3" Background="#F8FAFB" BorderBrush="#E5E8EB" BorderThickness="1"
                            CornerRadius="10" Padding="10" Margin="0,10,0,0">
                        <StackPanel>
                            <TextBlock Text="새 체커 키" Style="{StaticResource MutedText}" Margin="0,0,0,4"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" x:Name="AddKeyBox" Style="{StaticResource InputBox}"/>
                                <Button Grid.Column="2" x:Name="ConfirmAddButton" Content="확인"
                                        Style="{StaticResource PrimaryButton}" Click="ConfirmAddButton_Click"/>
                            </Grid>
                            <TextBlock Text="영문/숫자/밑줄(_)/마침표(.) 사용. 예: OVERLY_BROAD_CATCH"
                                       Style="{StaticResource MutedText}" Margin="0,6,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Right: editor -->
            <Border Grid.Column="2" Background="{StaticResource PanelBrush}" CornerRadius="14"
                    BorderBrush="{StaticResource LineBrush}" BorderThickness="1" Padding="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" x:Name="EditorTitle" Text="가이드 편집"
                               Style="{StaticResource SectionTitle}"/>
                    <TextBox Grid.Row="1" x:Name="EditorBox"
                             AcceptsReturn="True" AcceptsTab="True"
                             TextWrapping="NoWrap"
                             VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                             FontFamily="Consolas, D2Coding, Malgun Gothic" FontSize="13"
                             VerticalContentAlignment="Top"
                             Background="#0B1220" Foreground="#E5E7EB"
                             BorderBrush="#253044" BorderThickness="1" Padding="12"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Footer -->
        <Grid Grid.Row="3" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="StatusText" VerticalAlignment="Center"
                       Foreground="{StaticResource TextTertiaryBrush}" TextTrimming="CharacterEllipsis"/>
            <Button Grid.Column="1" x:Name="CloseButton" Content="닫기" Click="CloseButton_Click"/>
        </Grid>
    </Grid>
</Window>
